{
(* open Ltac_plugin *)

(* This one is necessary, to avoid message about missing wit_string *)
open Stdarg
(* open Pp *)
}

DECLARE PLUGIN "rocq-mebi.mebi"

(* ProofSolver - sim *)
(* TODO: automatically handle from bisim. i guess by starting a proof inside? *)
VERNAC COMMAND EXTEND MeBi_Sim CLASSIFIED AS QUERY
|![ proof ] 
  [ "MeBi" "Sim" "Solve" int(bound) ] ->
  { fun ~pstate -> Proof_solver.solve ~bound pstate }

|![ proof ] 
  [ "MeBi" "Sim" "Step" ] ->
  { fun ~pstate -> Proof_solver.step pstate }

|![ proof ] 
  [ "MeBi" "Sim" "Begin" reference(a) constr(x) "And" reference(b) constr(y) ] -> 
  { fun ~pstate -> Proof_solver.init pstate [] (x,a) (y,b) }

|![ proof ] 
  [ "MeBi" "Sim" "Begin" reference(a) constr(x) "And" reference(b) constr(y)
                 "Using" reference_list(rs) ] -> 
  { fun ~pstate -> Proof_solver.init pstate rs (x,a) (y,b) }
END

(* Bisimilarity *)
VERNAC COMMAND EXTEND MeBi_Run_Bisim CLASSIFIED AS QUERY
| ["MeBi" "Run" 
   "Bisim" constr(x) "With" reference(a) "And" constr(y) "With" reference(b)] -> 
  {
    let module W : Wrapper.S = (val Wrapper.make ()) in
    let _ = W.Command.run [] (W.Command.CheckBisim {a=(x, a); b=(y, b)}) 
            |> W.M.run ~reset_encoding:true
    in 
    let module Log : Logger.S = (val Api.make_logger ()) in
    Log.info "(Finished Checking Bisimilarity.)";
    ()
  }

| ["MeBi" "Run" 
   "Bisim" constr(x) "With" reference(a) "And" constr(y) "With" reference(b) 
   "Using" reference_list(rs)] -> 
  {
    let module W : Wrapper.S = (val Wrapper.make ()) in
    let _ = W.Command.run rs (W.Command.CheckBisim {a=(x, a); b=(y, b)})
            |> W.M.run ~reset_encoding:true
    in 
    let module Log : Logger.S = (val Api.make_logger ()) in
    Log.info "(Finished Checking Bisimilarity.)";
    ()
  }
END 


