VERNAC COMMAND EXTEND MeBi_Config_Reset CLASSIFIED AS QUERY
| ["MeBi" "Config" "Reset"]          -> { Api.reset_all            () }
| ["MeBi" "Config" "Reset" "Bounds"] -> { Api.reset_bounds_args    () }
| ["MeBi" "Config" "Reset" "Weak"]   -> { Api.reset_weak_args      () }
| ["MeBi" "Config" "Reset" "FailIf"] -> { Api.reset_the_fail_flags () }
| ["MeBi" "Config" "Reset" "Output"] -> { Api.reset_output_config  () }
END

(* Config -- graph bounds *)
VERNAC COMMAND EXTEND MeBi_Config_Bounds CLASSIFIED AS QUERY
| ["MeBi" "Config" "Bounds" "As" "Num" "States" int(x)] -> 
  { Api.set_the_bounds_args (Api.States x) }
| ["MeBi" "Config" "Bounds" "As" "Num" "Transitions" int(x)] -> 
  { Api.set_the_bounds_args (Api.Transitions x) }
END

(* Config -- weak_args for both *)
VERNAC COMMAND EXTEND MeBi_Config_Weak_Both CLASSIFIED AS QUERY
| ["MeBi" "Config" "Weak" "As" "Option" constr(x)] -> 
  { Api.set_the_weak_args (Some (Api.Option x)) None }
| ["MeBi" "Config" "Weak" "As" constr(x) "Of" reference(y)] -> 
  { Api.set_the_weak_args (Some (Api.Custom (x,y))) None }
END

(* Config -- weak_args for first *)
VERNAC COMMAND EXTEND MeBi_Config_Weak_First CLASSIFIED AS QUERY
| ["MeBi" "Config" "Weak1" "As" "Option" constr(x)] -> 
  { Api.set_the_weak_arg1 (Api.Option x) }
| ["MeBi" "Config" "Weak1" "As" constr(x) "Of" reference(y)] -> 
  { Api.set_the_weak_arg1 (Api.Custom (x,y)) }
END

(* Config -- weak_args for second *)
VERNAC COMMAND EXTEND MeBi_Config_Weak_Second CLASSIFIED AS QUERY
| ["MeBi" "Config" "Weak2" "As" "Option" constr(x)] -> 
  { Api.set_the_weak_arg2 (Api.Option x) }
| ["MeBi" "Config" "Weak2" "As" constr(x) "Of" reference(y)] -> 
  { Api.set_the_weak_arg2 (Api.Custom (x,y)) }
END

(* Config -- fail-if empty flag *)
VERNAC COMMAND EXTEND MeBi_Config_FailIf_Empty CLASSIFIED AS QUERY
| ["MeBi" "Config" "FailIf" "Empty" "True"] -> 
  { Api.set_fail_flag_empty true }
| ["MeBi" "Config" "FailIf" "Empty" "False"] -> 
  { Api.set_fail_flag_empty false }
END

(* Config -- fail-if incomplete flag *)
VERNAC COMMAND EXTEND MeBi_Config_FailIf_Incomplete CLASSIFIED AS QUERY
| ["MeBi" "Config" "FailIf" "Incomplete" "True"] -> 
  { Api.set_fail_flag_incomplete true }
| ["MeBi" "Config" "FailIf" "Incomplete" "False"] -> 
  { Api.set_fail_flag_incomplete false }
END

(* Config -- fail-if not-bisimilar flag *)
VERNAC COMMAND EXTEND MeBi_Config_FailIf_NotBisimilar CLASSIFIED AS QUERY
| ["MeBi" "Config" "FailIf" "NotBisimilar" "True"] -> 
  { Api.set_fail_flag_non_bisimilar true }
| ["MeBi" "Config" "FailIf" "NotBisimilar" "False"] -> 
  { Api.set_fail_flag_non_bisimilar false }
END

(* Config -- output *)
VERNAC COMMAND EXTEND MeBi_Config_Output CLASSIFIED AS QUERY
| ["MeBi" "Config" "Output" string(x) "True"] -> 
  { Api.set_output true x }
| ["MeBi" "Config" "Output" string(x) "False"] -> 
  { Api.set_output false x }
END

(* VERNAC COMMAND EXTEND MeBi_Help CLASSIFIED AS QUERY
(* TODO: update me *)
| ["MeBi" "Help"] -> {Logger.Default.show "TODO: Update Mebi_help"}
END  *)

VERNAC COMMAND EXTEND MeBi_Divider CLASSIFIED AS QUERY
(* for outputting messages -- useful for sifting through compiler output *)
| ["MeBi" "Message" string(x)] -> {Feedback.msg_info (Pp.str x)}
| ["MeBi" "Debug"   string(x)] -> {Feedback.msg_debug  (Pp.str x)}
| ["MeBi" "Divider"          ] -> {Feedback.msg_info (Pp.str "\n- - - - - - - - - - - - - - - -")}
| ["MeBi" "Divider" string(x)] -> {Feedback.msg_info (Pp.str (Printf.sprintf "\n- - - - - - - - - - - - - - - -\n%s" x))}
END 
